rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Friends collection rules
    match /friends/{friendId} {
      allow read, write: if true;
    }
    
    // Contributors collection rules
    match /contributors/{contributorId} {
      allow read, write: if true;
    }
    
    // Tracks collection rules
    match /tracks/{trackId} {
      allow read, write: if true;
    }
    
    // Announcements collection rules
    match /announcements/{announcementId} {
      allow read, write: if true;
    }
    
    // Test connection document rules
    match /test/{docId} {
      allow read, write: if true;
    }
  }
}
